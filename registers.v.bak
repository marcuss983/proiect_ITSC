module registers(
    input wire clk,
    input wire reset,
    input wire [15:0] data_in,
    input wire [3:0]  flag_in,
    input wire [15:0] pc_next_addr,
    input wire A_write_en, X_write_en, Y_write_en, SP_write_en,
    input wire PC_load_en, PC_inc_en, Flag_write_en,
    output reg [15:0] A_out, X_out, Y_out, PC_out, SP_out,
    output reg [3:0]  Flag_out
);
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            A_out    <= 16'h0000;
            X_out    <= 16'h0000;
            Y_out    <= 16'h0000;
            PC_out   <= 16'h0000;
            SP_out   <= 16'hFFFE;
            Flag_out <= 4'b0000;
        end else begin
            if (A_write_en)  A_out  <= data_in;
            if (X_write_en)  X_out  <= data_in;
            if (Y_write_en)  Y_out  <= data_in;
            if (SP_write_en) SP_out <= data_in;
            if (Flag_write_en) Flag_out <= flag_in;

            if (PC_load_en)
                PC_out <= pc_next_addr;
            else if (PC_inc_en)
                PC_out <= PC_out + 16'd1;
        end
    end
endmodule