module memory (
    input clk,
    input [15:0] addr,
    input [15:0] data_in,
    input mem_read_en,
    input mem_write_en,
    output reg [15:0] data_out
);
    reg [15:0] mem [0:65535];
    integer i;

    initial begin
        for (i = 0; i < 65536; i = i + 1)
            mem[i] = 16'h0000;
    end

    always @(posedge clk) begin
        if (mem_write_en)
            mem[addr] <= data_in;
    end

    always @* begin
        data_out = mem_read_en ? mem[addr] : 16'hXXXX;
    end
endmodule